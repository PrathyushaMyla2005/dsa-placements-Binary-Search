'''find the minimum element in a rotated sorted array
example:
Input: [3,4,5,1,2]
Output: 1'''
def find_minimum_rotated_sorted_array(nums):
    left = 0
    right = len(nums) - 1
    while left < right:
        mid = left + (right - left) // 2
        if nums[mid] > nums[right]: #the minimum is in the right half
            left = mid + 1
        else: #the minimum is in the left half
            right = mid
    return nums[left] #we return the minimum element
#test the function
nums = [3,4,5,1,2]
print(find_minimum_rotated_sorted_array(nums)) #1
'''tc: O(log n) because we are using binary search
sc: O(1) because we are using constant space
'''